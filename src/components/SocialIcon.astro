const icon = icons[name];
---

{
  icon && (
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width={size}
      height={size}
      viewBox="0 0 24 24"
      fill="currentColor"
      role="img"
      aria-label={icon.label}
      class={className}
      {...attrs}
    >
      <path d={icon.path} />
    </svg>
  )
}
