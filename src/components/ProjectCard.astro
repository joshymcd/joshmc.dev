---
export interface Props {
  title: string;
  description: string;
  technologies: string[];
  url: string;
}

const { title, description, technologies, url } = Astro.props;
---

<a
  href={url}
  target="_blank"
  rel="noopener"
  class="block border border-border bg-bg-muted rounded-lg p-6 hover:border-primary transition-colors group"
>
  <h3 class="text-lg font-semibold text-text-base group-hover:text-primary mb-2">
    {title}
  </h3>
  <p class="text-base text-text-muted mb-4">
    {description}
  </p>
  <div class="flex flex-wrap gap-2">
    {technologies.map((tech) => (
      <span class="px-2 py-1 text-xs bg-bg-base text-text-subtle rounded border border-border">
        {tech}
      </span>
    ))}
  </div>
</a>
